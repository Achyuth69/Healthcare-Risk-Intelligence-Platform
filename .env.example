# ============================================================
# HEALTHCARE RISK INTELLIGENCE PLATFORM — Environment Config
# Copy this file to backend/.env and fill in your values.
# NEVER commit .env — it is gitignored.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=HealthRiskAI
APP_ENV=development          # development | production
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# ── Database ─────────────────────────────────────────────────
# Local dev  → sqlite+aiosqlite:///./healthrisk_dev.db
# Supabase   → postgresql+asyncpg://postgres:PASS@db.XXX.supabase.co:5432/postgres
DATABASE_URL=sqlite+aiosqlite:///./healthrisk_dev.db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── JWT ──────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Encryption ───────────────────────────────────────────────
# Any 32-character string — used to encrypt PII fields (SSN, DOB)
ENCRYPTION_KEY=your-32-character-encryption-key-here!

# ── Redis ────────────────────────────────────────────────────
# Local dev  → redis://localhost:6379/0
# Upstash    → rediss://default:PASSWORD@us1-xxxx.upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# ── LLM — Groq API (FREE Llama 3 70B) ────────────────────────
# 1. Sign up free at https://console.groq.com (GitHub login works)
# 2. Go to API Keys → Create API Key → copy the gsk_xxx key
# 3. Paste it below — no GPU needed, 14,400 req/day free
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# ── ChromaDB (Vector Store for RAG) ──────────────────────────
# Leave as localhost for local dev — auto mock mode if not running
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=healthcare_docs

# ── HuggingFace (optional — only for local fine-tuned model) ──
# Not needed if GROQ_API_KEY is set
HUGGINGFACE_TOKEN=
LLM_MODEL_NAME=mock
FINE_TUNED_MODEL_PATH=./models/llama3-healthcare
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── AWS (optional — only for production S3 model storage) ────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=healthrisk-models
S3_PDF_BUCKET=healthrisk-documents

# ── CORS ─────────────────────────────────────────────────────
# Add your Vercel URL when deployed: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Model Paths ──────────────────────────────────────────────
MODEL_ARTIFACTS_DIR=./models

# ── Monitoring ───────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=admin

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=console     # console (dev) | json (production)
