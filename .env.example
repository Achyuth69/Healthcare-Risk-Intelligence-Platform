# ============================================================
# HEALTHCARE RISK INTELLIGENCE PLATFORM - Environment Config
# ============================================================

# Application
APP_NAME=HealthRiskAI
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# Database
DATABASE_URL=postgresql+asyncpg://postgres:Achyuth9725@db.pmhazxdanfriuhzvjodn.supabase.co:5432/postgres
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (for caching and rate limiting)
REDIS_URL=redis-cli --tls -u redis://default:gQAAAAAAAbnAAAIgcDJlNTIzNjFmMGViNzk0MTZmYjdjMTQzYWI2N2JkNjVkYw@superb-sheepdog-113088.upstash.io:6379

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=healthcare_docs

# LLM — Groq API (FREE — Llama 3 70B)
# 1. Go to https://console.groq.com
# 2. Sign up (free, no credit card)
# 3. Click API Keys → Create API Key
# 4. Copy the key that starts with gsk_
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# HuggingFace (only needed for local fine-tuned model, not required)
HUGGINGFACE_TOKEN=your-huggingface-token
LLM_MODEL_NAME=meta-llama/Meta-Llama-3-8B-Instruct
FINE_TUNED_MODEL_PATH=/models/llama3-healthcare-finetuned
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# AWS
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=healthrisk-models
S3_PDF_BUCKET=healthrisk-documents

# Encryption
ENCRYPTION_KEY=your-fernet-encryption-key-32-bytes-base64

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Model Paths
MODEL_ARTIFACTS_DIR=/app/models
XGBOOST_MODEL_PATH=/app/models/xgboost_risk_model.pkl
RF_MODEL_PATH=/app/models/rf_risk_model.pkl
LGBM_MODEL_PATH=/app/models/lgbm_risk_model.pkl
SCALER_PATH=/app/models/feature_scaler.pkl
FEATURE_NAMES_PATH=/app/models/feature_names.json

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
